# Configuration file for concentrator CS-DI-IOC-01.

# This file is executed by the concentrator on startup, so adding
# undocumented lines is perilous!

# Location of the beam current dependency files and the format of the BCD
# file name.
BCD_SourceDir = '/home/ops/diagnostics/bcd'
# This file format will be formatted with a dictionary containing the
# following entries:
#   ma  Configured current in mA
BCD_FileFormat = 'BCD_%(ma)dmA_%(db)ddB_%(xy)c'

# List of supported attenuator settings.  Each entry is a pair of values:
# attenuation in dB and the nominal current at that attenuation.
ATTENUATOR_LIST = (
    (22, 10),
    (35, 60),
    (46, 125),
    (50, 200),
)
